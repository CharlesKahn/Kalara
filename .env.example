# Brio Pilot - Environment Variables
# Copy this to .env and fill in your keys

# Anthropic (Claude) API key
ANTHROPIC_API_KEY=sk-ant-...

# Recall.ai API key - get from app.recall.ai
RECALL_API_KEY=...

# Your public webhook URL (use ngrok for local dev)
# Example: https://abc123.ngrok.io
WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# Google OAuth (optional — enables participant profile pictures and account linking)
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to register: http://localhost:3847/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
